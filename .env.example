# Private key for contract deployment (without 0x prefix)
# ⚠️ NEVER commit your actual private key to git!
PRIVATE_KEY=your_private_key_here

# BscScan API key for contract verification
# Get from: https://bscscan.com/myapikey
BSCSCAN_API_KEY=your_bscscan_api_key_here

# RPC URLs (optional - defaults are provided in hardhat.config.js)
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
BSC_MAINNET_RPC=https://bsc-dataseed.binance.org/

# MeeChain Badge SBT Configuration
MEECHAIN_BADGE_RPC_URL=https://bsc-dataseed.binance.org
MEECHAIN_BADGE_PRIVATE_KEY=your_badge_private_key_here
MEECHAIN_BADGE_CONTRACT_ADDRESS=0x...
