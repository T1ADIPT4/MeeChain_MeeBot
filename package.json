{
  "name": "meechain-meebot",
  "version": "1.0.0",
  "description": "Fallback-aware quest verification and badge minting system for MeeChain",
  "main": "dist/QuestManager.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:legacy": "npm run build && node dist/src/test.js",
    "test:tts-badge": "jest --testPathPatterns=tts-badge",
    "copilot-test-tts-badge": "jest --testPathPatterns=tts-badge",
    "dev": "tsc --watch",
    "example": "npm run build && node dist/src/example.js",
    "demo:settings": "npm run build && node dist/examples/settings-support-demo.js"
  },
  "keywords": [
    "meechain",
    "quest",
    "badge",
    "nft",
    "web3",
    "fallback-aware"
  ],
  "author": "MeeChain Team",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.4",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "react": "^18.2.0"
  }
}
