{
  "name": "meechain-meebot",
  "version": "1.0.0",
  "description": "Fallback-aware quest verification and badge minting system for MeeChain",
  "main": "dist/QuestManager.js",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy",
    "copilot-test-tts-badge": "jest tests/ttsQuest.test.ts",
    "dev:dashboard": "vite",
    "example": "npm run build && node dist/examples/auto-deploy-workflow-demo.js",
    "demo:settings": "npm run build && node dist/examples/settings-support-demo.js",
    "demo:tts-quest": "npm run build && node dist/examples/tts-quest-demo.js",
    "demo:deploy-registry": "npm run build && node dist/examples/deploy-registry-demo.js",
    "demo:dashboard": "npm run build && node dist/examples/dashboard-integration-demo.js",
    "demo:auto-deploy": "npm run build && node dist/examples/auto-deploy-workflow-demo.js",
    "demo:supply": "node examples/meechain-supply-demo.js",
    "deploy:badge": "npx hardhat run scripts/deploy-badge.js",
    "deploy:quest": "node --loader ts-node/esm scripts/deploy.ts Quest",
    "deploy:fallback": "node --loader ts-node/esm scripts/deploy.ts Fallback",
    "deploy:supply": "npx hardhat run scripts/deployMeeChainSupply.js",
    "registry:update": "node --loader ts-node/esm scripts/updateRegistry.ts",
    "registry:validate": "node --loader ts-node/esm scripts/validateRegistry.ts",
    "ipfs:generate-metadata": "node copilot/implement-ipfs-uploader/metadata-generator.js",
    "ipfs:test-metadata": "node copilot/implement-ipfs-uploader/test-metadata-generator.js",
    "ipfs:meebot-demo": "node copilot/implement-ipfs-uploader/meebot-milestone-example.js",
    "verify:meebot": "node copilot/verifyMeeBotFlow.js"
  },
  "keywords": [
    "meechain",
    "quest",
    "badge",
    "nft",
    "web3",
    "fallback-aware"
  ],
  "author": "MeeChain Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.0",
    "jest": "^30.2.0",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "chart.js": "^4.5.0",
    "firebase-admin": "^13.5.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-router-dom": "^7.9.4"
  },
  "directories": {
    "example": "examples",
    "test": "tests"
  }
}
