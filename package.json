{
  "name": "meechain-meebot",
  "version": "1.0.0",
  "description": "Fallback-aware quest verification and badge minting system for MeeChain",
  "main": "dist/QuestManager.js",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "build:backend": "tsc",
    "build:frontend": "vite build",
    "test": "npm run build:backend && node dist/test.js",
    "dev": "vite",
    "dev:backend": "tsc --watch",
    "preview": "vite preview",
    "example": "npm run build:backend && node dist/example.js",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "keywords": [
    "meechain",
    "quest",
    "badge",
    "nft",
    "web3",
    "fallback-aware"
  ],
  "author": "MeeChain Team",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
