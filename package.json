{
  "name": "meechain-meebot",
  "version": "1.0.0",
  "description": "Fallback-aware quest verification and badge minting system for MeeChain",
  "main": "dist/QuestManager.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "copilot-test-tts-badge": "jest tests/ttsQuest.test.ts",
    "dev": "tsc --watch",
    "example": "npm run build && node dist/example.js",
    "demo:settings": "npm run build && node dist/examples/settings-support-demo.js",
    "demo:tts-quest": "npm run build && node dist/examples/tts-quest-demo.js",
    "demo:deploy-registry": "npm run build && node dist/examples/deploy-registry-demo.js",
    "demo:deploy-automation": "npm run build && node dist/examples/deploy-automation-demo.js",
    "deploy": "npm run build && node dist/scripts/deploy.js",
    "validate-registry": "npm run build && node dist/scripts/validateRegistry.js",
    "export-logs": "npm run build && node dist/scripts/exportLogs.js"
  },
  "keywords": [
    "meechain",
    "quest",
    "badge",
    "nft",
    "web3",
    "fallback-aware"
  ],
  "author": "MeeChain Team",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.4",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "react": "^18.2.0"
  }
}
