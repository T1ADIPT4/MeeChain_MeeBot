# RPC URL for BSC network
RPC_URL=https://bsc-dataseed.binance.org

# MeeChainSupply contract address
CONTRACT_ADDRESS=0x001aCFF4ABF83647bAc745cf9D98a49F6181f15F

# MeeBot wallet address (must be authorized in the contract)
MEEBOT_WALLET_ADDRESS=0xYourSignerAddress

# Private key for signing transactions (without 0x prefix)
# ⚠️ NEVER commit your actual private key to git!
PRIVATE_KEY=your_private_key_here

# Server port (optional, defaults to 3000)
PORT=3000
